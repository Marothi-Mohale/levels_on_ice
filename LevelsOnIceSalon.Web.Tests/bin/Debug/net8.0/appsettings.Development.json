{
  "App": {
    "UseHttpsRedirection": false
  },
  "Captcha": {
    "Enabled": false,
    "Provider": "Turnstile",
    "MinimumScore": 0.5
  },
  "DataBackups": {
    "Enabled": true,
    "DirectoryPath": "App_Data/Backups",
    "IntervalHours": 24,
    "RetentionDays": 14,
    "RunOnStartup": true
  },
  "Site": {
    "BaseUrl": "http://localhost:5099",
    "Name": "Levels On Ice Salon",
    "DefaultSocialImage": "/images/salon/hair-featured-01.jpg",
    "PhoneNumber": "081 390 6634",
    "Email": "levelsonicegroup@gmail.com",
    "StreetAddress": "102 Main Road",
    "AddressLocality": "Mowbray",
    "AddressRegion": "Cape Town",
    "PostalCode": "",
    "AddressCountry": "ZA",
    "PriceRange": "$$",
    "InstagramUrl": "https://www.instagram.com/levelsonicesalon/",
    "FacebookUrl": "https://www.facebook.com/LevelsOnIceSalon/",
    "TikTokUrl": "https://www.tiktok.com/@levelsonicesalon1"
  },
  "Database": {
    "Provider": "Sqlite",
    "ApplyMigrationsOnStartup": true,
    "SeedSampleDataOnStartup": true
  },
  "ApiDocumentation": {
    "Enabled": true
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=App_Data/levels-on-ice-salon.dev.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  }
}
