{
  "App": {
    "UseHttpsRedirection": true
  },
  "Captcha": {
    "Enabled": false,
    "Provider": "Turnstile",
    "MinimumScore": 0.5
  },
  "DataBackups": {
    "Enabled": true,
    "DirectoryPath": "App_Data/Backups",
    "IntervalHours": 24,
    "RetentionDays": 30,
    "RunOnStartup": true
  },
  "Site": {
    "BaseUrl": "https://www.levelsonicesalon.co.za",
    "Name": "Levels On Ice Salon",
    "DefaultSocialImage": "/images/salon/hair-featured-01.jpg",
    "PhoneNumber": "081 390 6634",
    "Email": "levelsonicegroup@gmail.com",
    "StreetAddress": "102 Main Road",
    "AddressLocality": "Mowbray",
    "AddressRegion": "Cape Town",
    "PostalCode": "",
    "AddressCountry": "ZA",
    "PriceRange": "$$",
    "InstagramUrl": "https://www.instagram.com/levelsonicesalon/",
    "FacebookUrl": "https://www.facebook.com/LevelsOnIceSalon/",
    "TikTokUrl": "https://www.tiktok.com/@levelsonicesalon1"
  },
  "Database": {
    "Provider": "Sqlite",
    "ApplyMigrationsOnStartup": false,
    "SeedSampleDataOnStartup": false
  },
  "ApiDocumentation": {
    "Enabled": false
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=App_Data/levels-on-ice-salon.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Hosting.Diagnostics": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*"
}
