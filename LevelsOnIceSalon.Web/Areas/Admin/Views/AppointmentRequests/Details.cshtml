@model AppointmentRequest
@{ ViewData["Title"] = "Appointment Request Details"; }
<div class="admin-detail-card"><div class="admin-detail-grid"><div><span class="card-kicker">Client</span><h2>@Model.FullName</h2><p>@Model.PhoneNumber</p><p>@Model.Email</p></div><div><span class="card-kicker">Status</span><h3>@Model.Status</h3><p>Requested: @Model.PreferredDate?.ToString("yyyy-MM-dd") @if(Model.PreferredTime.HasValue){<span>@Model.PreferredTime.Value.ToString("HH\\:mm")</span>}</p><p>Service: @Model.Service?.Name</p></div></div><div class="admin-detail-section"><strong>Notes</strong><p class="u-text-muted mb-0">@(!string.IsNullOrWhiteSpace(Model.Notes) ? Model.Notes : "No client notes provided.")</p></div><div class="admin-detail-section"><strong>Admin Notes</strong><p class="u-text-muted mb-0">@(!string.IsNullOrWhiteSpace(Model.AdminNotes) ? Model.AdminNotes : "No admin notes yet.")</p></div><div class="admin-form-actions"><a class="btn btn-brand" asp-action="Edit" asp-route-id="@Model.Id">Update Status</a><a class="btn btn-soft" asp-action="Index">Back</a></div></div>
