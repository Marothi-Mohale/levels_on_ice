@model PagedResult<AppointmentRequest>
@{ ViewData["Title"] = "Appointment Requests"; }
<div class="admin-list-shell"><div class="admin-toolbar"><p class="u-text-muted mb-0">Review incoming bookings and keep status updates tidy.</p></div><div class="admin-table-card"><table class="table admin-table align-middle"><thead><tr><th>Client</th><th>Service</th><th>Requested</th><th>Status</th><th class="text-end">Actions</th></tr></thead><tbody>@foreach (var item in Model.Items){<tr><td><strong>@item.FullName</strong><div class="admin-table-subtext">@item.PhoneNumber @if (!string.IsNullOrWhiteSpace(item.Email)){<span>/ @item.Email</span>}</div></td><td>@item.Service?.Name</td><td>@item.PreferredDate?.ToString("yyyy-MM-dd") @if(item.PreferredTime.HasValue){<span>@item.PreferredTime.Value.ToString("HH\\:mm")</span>}</td><td>@item.Status</td><td class="text-end"><a class="btn btn-sm btn-soft" asp-action="Details" asp-route-id="@item.Id">View</a> <a class="btn btn-sm btn-brand" asp-action="Edit" asp-route-id="@item.Id">Update</a></td></tr>}</tbody></table></div><partial name="~/Areas/Admin/Views/Shared/_AdminPagination.cshtml" model="Model" /></div>
