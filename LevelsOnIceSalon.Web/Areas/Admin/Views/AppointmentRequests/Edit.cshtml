@model AppointmentRequestAdminFormViewModel
@{ ViewData["Title"] = "Update Appointment Request"; }
<form method="post" class="admin-form-card"><div asp-validation-summary="ModelOnly" class="booking-status booking-status-error" role="alert"></div><p class="u-text-muted">Updating request for <strong>@Model.CustomerName</strong>@if(!string.IsNullOrWhiteSpace(Model.ServiceName)){<span> - @Model.ServiceName</span>}</p><div class="row g-4"><div class="col-md-4"><label asp-for="Status" class="form-label"></label><select asp-for="Status" asp-items="Html.GetEnumSelectList<AppointmentRequestStatus>()" class="form-select booking-input"></select></div><div class="col-12"><label asp-for="AdminNotes" class="form-label"></label><textarea asp-for="AdminNotes" class="form-control booking-input booking-textarea" rows="5"></textarea></div></div><div class="admin-form-actions"><button type="submit" class="btn btn-brand">Save Changes</button><a class="btn btn-soft" asp-action="Index">Cancel</a></div></form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
