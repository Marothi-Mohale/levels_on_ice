@model PagedResult<ServiceCategory>
@{
    ViewData["Title"] = "Service Categories";
}

<div class="admin-list-shell">
    <div class="admin-toolbar">
        <p class="u-text-muted mb-0">Organize the salon menu into polished category groups.</p>
        <a class="btn btn-brand" asp-action="Create">Add Category</a>
    </div>
    <div class="admin-table-card">
        <table class="table admin-table align-middle">
            <thead><tr><th>Name</th><th>Slug</th><th>Sort</th><th>Status</th><th class="text-end">Actions</th></tr></thead>
            <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td><strong>@item.Name</strong><div class="admin-table-subtext">@item.Description</div></td>
                    <td>@item.Slug</td>
                    <td>@item.DisplayOrder</td>
                    <td>@(item.IsActive ? "Active" : "Hidden")</td>
                    <td class="text-end"><a class="btn btn-sm btn-soft" asp-action="Edit" asp-route-id="@item.Id">Edit</a> <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Delete</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
