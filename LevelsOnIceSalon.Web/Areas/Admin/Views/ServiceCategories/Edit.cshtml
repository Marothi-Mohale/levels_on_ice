@model ServiceCategoryFormViewModel
@{
    ViewData["Title"] = Model.Id.HasValue ? "Edit Service Category" : "Create Service Category";
}

<form method="post" class="admin-form-card">
    <div asp-validation-summary="ModelOnly" class="booking-status booking-status-error" role="alert"></div>
    <div class="row g-4">
        <div class="col-md-6"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control booking-input" /><span asp-validation-for="Name" class="field-validation text-danger"></span></div>
        <div class="col-md-6"><label asp-for="Slug" class="form-label"></label><input asp-for="Slug" class="form-control booking-input" /><span asp-validation-for="Slug" class="field-validation text-danger"></span></div>
        <div class="col-12"><label asp-for="Description" class="form-label"></label><textarea asp-for="Description" class="form-control booking-input booking-textarea" rows="4"></textarea><span asp-validation-for="Description" class="field-validation text-danger"></span></div>
        <div class="col-md-4"><label asp-for="DisplayOrder" class="form-label"></label><input asp-for="DisplayOrder" class="form-control booking-input" /><span asp-validation-for="DisplayOrder" class="field-validation text-danger"></span></div>
        <div class="col-md-4 d-flex align-items-center"><div class="form-check mt-4"><input asp-for="IsActive" class="form-check-input" /><label asp-for="IsActive" class="form-check-label"></label></div></div>
    </div>
    <div class="admin-form-actions"><button type="submit" class="btn btn-brand">Save Category</button><a class="btn btn-soft" asp-action="Index">Cancel</a></div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
