@model ServiceCategory
@{
    ViewData["Title"] = "Delete Service Category";
}

<div class="admin-delete-card">
    <p class="eyebrow">Delete Category</p>
    <h2>@Model.Name</h2>
    <p class="u-text-muted">This permanently removes the category if there are no services attached.</p>
    <form method="post" class="admin-form-actions">
        <button type="submit" class="btn btn-danger">Confirm Delete</button>
        <a class="btn btn-soft" asp-action="Index">Cancel</a>
    </form>
</div>
