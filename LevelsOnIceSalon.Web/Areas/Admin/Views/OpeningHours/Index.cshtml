@model IReadOnlyList<OpeningHour>
@{ ViewData["Title"] = "Opening Hours"; }
<div class="admin-list-shell"><div class="admin-toolbar"><p class="u-text-muted mb-0">Manage the salon schedule shown on the public contact page.</p><a class="btn btn-brand" asp-action="Create">Add Day</a></div><div class="admin-table-card"><table class="table admin-table align-middle"><thead><tr><th>Day</th><th>Hours</th><th>Notes</th><th class="text-end">Actions</th></tr></thead><tbody>@foreach (var item in Model){<tr><td><strong>@Enum.GetName(typeof(DayOfWeek), item.DayOfWeek)</strong></td><td>@(item.IsClosed ? "Closed" : $"{item.OpenTime:HH\\:mm} - {item.CloseTime:HH\\:mm}")</td><td>@item.Notes</td><td class="text-end"><a class="btn btn-sm btn-soft" asp-action="Edit" asp-route-id="@item.Id">Edit</a> <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Delete</a></td></tr>}</tbody></table></div></div>
