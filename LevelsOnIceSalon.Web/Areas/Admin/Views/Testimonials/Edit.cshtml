@model TestimonialFormViewModel
@{ ViewData["Title"] = Model.Id.HasValue ? "Edit Testimonial" : "Create Testimonial"; }
<form method="post" class="admin-form-card"><div asp-validation-summary="ModelOnly" class="booking-status booking-status-error" role="alert"></div><div class="row g-4"><div class="col-md-6"><label asp-for="CustomerName" class="form-label"></label><input asp-for="CustomerName" class="form-control booking-input" /></div><div class="col-md-3"><label asp-for="Rating" class="form-label"></label><input asp-for="Rating" class="form-control booking-input" /></div><div class="col-md-3"><label asp-for="DisplayOrder" class="form-label"></label><input asp-for="DisplayOrder" class="form-control booking-input" /></div><div class="col-md-6"><label asp-for="ServiceName" class="form-label"></label><input asp-for="ServiceName" class="form-control booking-input" /></div><div class="col-md-6"><label asp-for="SourceType" class="form-label"></label><select asp-for="SourceType" asp-items="Html.GetEnumSelectList<TestimonialSourceType>()" class="form-select booking-input"></select></div><div class="col-12"><label asp-for="SourceUrl" class="form-label"></label><input asp-for="SourceUrl" class="form-control booking-input" /></div><div class="col-12"><label asp-for="Quote" class="form-label"></label><textarea asp-for="Quote" class="form-control booking-input booking-textarea" rows="5"></textarea></div><div class="col-md-4"><div class="form-check mt-3"><input asp-for="IsFeatured" class="form-check-input" /><label asp-for="IsFeatured" class="form-check-label"></label></div></div><div class="col-md-4"><div class="form-check mt-3"><input asp-for="IsPublished" class="form-check-input" /><label asp-for="IsPublished" class="form-check-label"></label></div></div></div><div class="admin-form-actions"><button type="submit" class="btn btn-brand">Save Testimonial</button><a class="btn btn-soft" asp-action="Index">Cancel</a></div></form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
