@model PagedResult<Testimonial>
@{ ViewData["Title"] = "Manage Testimonials"; }
<div class="admin-list-shell"><div class="admin-toolbar"><p class="u-text-muted mb-0">Curate social proof and featured client feedback.</p><a class="btn btn-brand" asp-action="Create">Add Testimonial</a></div><div class="admin-table-card"><table class="table admin-table align-middle"><thead><tr><th>Client</th><th>Rating</th><th>Service</th><th>Status</th><th class="text-end">Actions</th></tr></thead><tbody>@foreach (var item in Model.Items){<tr><td><strong>@item.CustomerName</strong><div class="admin-table-subtext">@item.Quote</div></td><td>@item.Rating / 5</td><td>@item.ServiceName</td><td>@(item.IsPublished ? "Published" : "Draft") / @(item.IsFeatured ? "Featured" : "Standard")</td><td class="text-end"><a class="btn btn-sm btn-soft" asp-action="Edit" asp-route-id="@item.Id">Edit</a> <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Delete</a></td></tr>}</tbody></table></div><partial name="~/Areas/Admin/Views/Shared/_AdminPagination.cshtml" model="Model" /></div>
