@model PagedResult<ContactMessage>
@{ ViewData["Title"] = "Contact Messages"; }
<div class="admin-list-shell"><div class="admin-toolbar"><p class="u-text-muted mb-0">Stay on top of incoming contact enquiries and follow-up notes.</p></div><div class="admin-table-card"><table class="table admin-table align-middle"><thead><tr><th>Sender</th><th>Subject</th><th>Received</th><th>Status</th><th class="text-end">Actions</th></tr></thead><tbody>@foreach (var item in Model.Items){<tr><td><strong>@item.FullName</strong><div class="admin-table-subtext">@item.Email @if(!string.IsNullOrWhiteSpace(item.PhoneNumber)){<span>/ @item.PhoneNumber</span>}</div></td><td>@item.Subject</td><td>@item.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td><td>@item.Status</td><td class="text-end"><a class="btn btn-sm btn-soft" asp-action="Details" asp-route-id="@item.Id">View</a> <a class="btn btn-sm btn-brand" asp-action="Edit" asp-route-id="@item.Id">Update</a></td></tr>}</tbody></table></div><partial name="~/Areas/Admin/Views/Shared/_AdminPagination.cshtml" model="Model" /></div>
