@model ContactMessage
@{ ViewData["Title"] = "Contact Message Details"; }
<div class="admin-detail-card"><div class="admin-detail-grid"><div><span class="card-kicker">Sender</span><h2>@Model.FullName</h2><p>@Model.Email</p><p>@Model.PhoneNumber</p></div><div><span class="card-kicker">Subject</span><h3>@Model.Subject</h3><p>Status: @Model.Status</p><p>Received: @Model.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</p></div></div><div class="admin-detail-section"><strong>Message</strong><p class="u-text-muted mb-0">@Model.Message</p></div><div class="admin-detail-section"><strong>Admin Reply Notes</strong><p class="u-text-muted mb-0">@(!string.IsNullOrWhiteSpace(Model.AdminReplyNotes) ? Model.AdminReplyNotes : "No reply notes yet.")</p></div><div class="admin-form-actions"><a class="btn btn-brand" asp-action="Edit" asp-route-id="@Model.Id">Update Status</a><a class="btn btn-soft" asp-action="Index">Back</a></div></div>
