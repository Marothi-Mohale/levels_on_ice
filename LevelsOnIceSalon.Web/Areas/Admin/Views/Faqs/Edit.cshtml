@model FaqFormViewModel
@{ ViewData["Title"] = Model.Id.HasValue ? "Edit FAQ" : "Create FAQ"; }
<form method="post" class="admin-form-card"><div asp-validation-summary="ModelOnly" class="booking-status booking-status-error" role="alert"></div><div class="row g-4"><div class="col-12"><label asp-for="Question" class="form-label"></label><input asp-for="Question" class="form-control booking-input" /></div><div class="col-12"><label asp-for="Answer" class="form-label"></label><textarea asp-for="Answer" class="form-control booking-input booking-textarea" rows="5"></textarea></div><div class="col-md-6"><label asp-for="Category" class="form-label"></label><input asp-for="Category" class="form-control booking-input" /></div><div class="col-md-3"><label asp-for="DisplayOrder" class="form-label"></label><input asp-for="DisplayOrder" class="form-control booking-input" /></div><div class="col-md-3"><div class="form-check mt-3"><input asp-for="IsPublished" class="form-check-input" /><label asp-for="IsPublished" class="form-check-label"></label></div></div></div><div class="admin-form-actions"><button type="submit" class="btn btn-brand">Save FAQ</button><a class="btn btn-soft" asp-action="Index">Cancel</a></div></form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
