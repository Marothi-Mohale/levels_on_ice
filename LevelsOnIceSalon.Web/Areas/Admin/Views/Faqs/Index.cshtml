@model PagedResult<FAQ>
@{ ViewData["Title"] = "Manage FAQs"; }
<div class="admin-list-shell"><div class="admin-toolbar"><p class="u-text-muted mb-0">Keep booking and visit questions clear for clients.</p><a class="btn btn-brand" asp-action="Create">Add FAQ</a></div><div class="admin-table-card"><table class="table admin-table align-middle"><thead><tr><th>Question</th><th>Category</th><th>Sort</th><th>Status</th><th class="text-end">Actions</th></tr></thead><tbody>@foreach (var item in Model.Items){<tr><td><strong>@item.Question</strong><div class="admin-table-subtext">@item.Answer</div></td><td>@item.Category</td><td>@item.DisplayOrder</td><td>@(item.IsPublished ? "Published" : "Draft")</td><td class="text-end"><a class="btn btn-sm btn-soft" asp-action="Edit" asp-route-id="@item.Id">Edit</a> <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Delete</a></td></tr>}</tbody></table></div><partial name="~/Areas/Admin/Views/Shared/_AdminPagination.cshtml" model="Model" /></div>
