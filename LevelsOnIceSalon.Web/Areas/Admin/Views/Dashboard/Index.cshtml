@{
    ViewData["Title"] = "Admin Dashboard";
}

<section class="content-section">
    <div class="container">
        <p class="eyebrow">Admin</p>
        <h1 class="display-title h2">Content Management Shell</h1>
        <div class="row g-4 mt-1">
            <div class="col-md-6 col-lg-3">
                <div class="feature-card">
                    <h3>Services</h3>
                    <p>Manage categories, treatments, and featured offerings.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="feature-card">
                    <h3>Gallery</h3>
                    <p>Upload salon images and organize visual collections.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="feature-card">
                    <h3>Testimonials</h3>
                    <p>Control featured customer reviews and social proof.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="feature-card">
                    <h3>Bookings</h3>
                    <p>Review and update appointment request statuses.</p>
                </div>
            </div>
        </div>
    </div>
</section>
