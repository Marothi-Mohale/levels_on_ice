@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="admin-page-shell">
    <div class="admin-stats-grid">
        <div class="admin-stat-card"><span class="card-kicker">Services</span><strong>@Model.ServiceCount</strong></div>
        <div class="admin-stat-card"><span class="card-kicker">Categories</span><strong>@Model.CategoryCount</strong></div>
        <div class="admin-stat-card"><span class="card-kicker">Gallery</span><strong>@Model.GalleryImageCount</strong></div>
        <div class="admin-stat-card"><span class="card-kicker">Testimonials</span><strong>@Model.TestimonialCount</strong></div>
        <div class="admin-stat-card"><span class="card-kicker">FAQs</span><strong>@Model.FaqCount</strong></div>
        <div class="admin-stat-card"><span class="card-kicker">Pending Appointments</span><strong>@Model.PendingAppointmentCount</strong></div>
        <div class="admin-stat-card"><span class="card-kicker">New Messages</span><strong>@Model.NewContactMessageCount</strong></div>
        <div class="admin-stat-card"><span class="card-kicker">Settings</span><strong>@Model.SiteSettingCount</strong></div>
    </div>

    <div class="admin-card-grid mt-4">
        <a class="admin-action-card" asp-controller="Services" asp-action="Index"><h2>Manage Services</h2><p>Update pricing, descriptions, featured treatments, and booking visibility.</p></a>
        <a class="admin-action-card" asp-controller="GalleryImages" asp-action="Index"><h2>Manage Gallery Images</h2><p>Upload visual content, set captions, and control published salon imagery.</p></a>
        <a class="admin-action-card" asp-controller="Testimonials" asp-action="Index"><h2>Manage Testimonials</h2><p>Publish client love, curate featured reviews, and keep social proof current.</p></a>
        <a class="admin-action-card" asp-controller="AppointmentRequests" asp-action="Index"><h2>Review Appointment Requests</h2><p>Update statuses, track notes, and stay on top of incoming enquiries.</p></a>
    </div>
</div>
