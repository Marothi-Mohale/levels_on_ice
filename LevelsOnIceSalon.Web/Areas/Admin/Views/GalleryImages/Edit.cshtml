@model GalleryImageFormViewModel
@{
    ViewData["Title"] = Model.Id.HasValue ? "Edit Gallery Image" : "Create Gallery Image";
}
<form method="post" enctype="multipart/form-data" class="admin-form-card">
    <div asp-validation-summary="ModelOnly" class="booking-status booking-status-error" role="alert"></div>
    <input asp-for="ExistingImagePath" type="hidden" />
    <div class="row g-4">
        <div class="col-md-6"><label asp-for="Title" class="form-label"></label><input asp-for="Title" class="form-control booking-input" /></div>
        <div class="col-md-6"><label asp-for="ServiceId" class="form-label"></label><select asp-for="ServiceId" asp-items="ViewBag.Services" class="form-select booking-input"><option value="">No linked service</option></select></div>
        <div class="col-md-6"><label asp-for="ImageFile" class="form-label"></label><input asp-for="ImageFile" class="form-control booking-input" type="file" accept="image/*" /></div>
        <div class="col-md-6"><label asp-for="AltText" class="form-label"></label><input asp-for="AltText" class="form-control booking-input" /></div>
        <div class="col-md-4"><label asp-for="ImageType" class="form-label"></label><select asp-for="ImageType" asp-items="Html.GetEnumSelectList<GalleryImageType>()" class="form-select booking-input"></select></div>
        <div class="col-md-4"><label asp-for="DisplayOrder" class="form-label"></label><input asp-for="DisplayOrder" class="form-control booking-input" /></div>
        <div class="col-md-4"><label asp-for="SourceType" class="form-label"></label><input asp-for="SourceType" class="form-control booking-input" /></div>
        <div class="col-12"><label asp-for="SourceUrl" class="form-label"></label><input asp-for="SourceUrl" class="form-control booking-input" /></div>
        <div class="col-12"><label asp-for="Caption" class="form-label"></label><textarea asp-for="Caption" class="form-control booking-input" rows="3"></textarea></div>
        <div class="col-md-4"><div class="form-check mt-3"><input asp-for="IsFeatured" class="form-check-input" /><label asp-for="IsFeatured" class="form-check-label"></label></div></div>
        <div class="col-md-4"><div class="form-check mt-3"><input asp-for="IsPublished" class="form-check-input" /><label asp-for="IsPublished" class="form-check-label"></label></div></div>
        @if (!string.IsNullOrWhiteSpace(Model.ExistingImagePath)) { <div class="col-12"><img src="@Model.ExistingImagePath" alt="@Model.AltText" class="admin-preview-image" /></div> }
    </div>
    <div class="admin-form-actions"><button type="submit" class="btn btn-brand">Save Image</button><a class="btn btn-soft" asp-action="Index">Cancel</a></div>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
