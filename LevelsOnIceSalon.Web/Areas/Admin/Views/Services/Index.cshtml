@model PagedResult<Service>
@{
    ViewData["Title"] = "Services";
}

<div class="admin-list-shell">
    <div class="admin-toolbar">
        <p class="u-text-muted mb-0">Manage the public service menu and booking-ready content.</p>
        <a class="btn btn-brand" asp-action="Create">Add Service</a>
    </div>
    <div class="admin-table-card">
        <table class="table admin-table align-middle">
            <thead><tr><th>Service</th><th>Category</th><th>Price</th><th>Flags</th><th class="text-end">Actions</th></tr></thead>
            <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td><strong>@item.Name</strong><div class="admin-table-subtext">@item.ShortDescription</div></td>
                    <td>@item.ServiceCategory?.Name</td>
                    <td>@(item.Price.HasValue ? $"R{item.Price.Value:0}" : "Quote")</td>
                    <td>@(item.IsFeatured ? "Featured" : "Standard") / @(item.IsActive ? "Active" : "Hidden")</td>
                    <td class="text-end"><a class="btn btn-sm btn-soft" asp-action="Edit" asp-route-id="@item.Id">Edit</a> <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Delete</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <partial name="~/Areas/Admin/Views/Shared/_AdminPagination.cshtml" model="Model" />
</div>
