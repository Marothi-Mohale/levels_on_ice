@model dynamic
@{
    var routeValues = ViewData["PaginationRouteValues"] as IDictionary<string, string> ?? new Dictionary<string, string>();
}

@if (Model.TotalPages > 1)
{
    <nav aria-label="Admin pagination" class="admin-pagination-shell">
        <ul class="pagination admin-pagination mb-0">
            <li class="page-item @(Model.HasPreviousPage ? string.Empty : "disabled")">
                <a class="page-link" href="?page=@(Model.PageNumber - 1)">Previous</a>
            </li>
            @for (var pageNumber = 1; pageNumber <= Model.TotalPages; pageNumber++)
            {
                <li class="page-item @(pageNumber == Model.PageNumber ? "active" : string.Empty)">
                    <a class="page-link" href="?page=@pageNumber">@pageNumber</a>
                </li>
            }
            <li class="page-item @(Model.HasNextPage ? string.Empty : "disabled")">
                <a class="page-link" href="?page=@(Model.PageNumber + 1)">Next</a>
            </li>
        </ul>
    </nav>
}
