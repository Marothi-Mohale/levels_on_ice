<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Levels On Ice Salon Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600;700&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="admin-shell">
    <div class="admin-app">
        <aside class="admin-sidebar">
            <a class="admin-brand" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                <span class="admin-brand-top">Levels On Ice</span>
                <span class="admin-brand-bottom">Admin</span>
            </a>
            <nav class="admin-nav" aria-label="Admin navigation">
                <a class="admin-nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                <a class="admin-nav-link" asp-area="Admin" asp-controller="Services" asp-action="Index">Services</a>
                <a class="admin-nav-link" asp-area="Admin" asp-controller="ServiceCategories" asp-action="Index">Service Categories</a>
                <a class="admin-nav-link" asp-area="Admin" asp-controller="GalleryImages" asp-action="Index">Gallery Images</a>
                <a class="admin-nav-link" asp-area="Admin" asp-controller="Testimonials" asp-action="Index">Testimonials</a>
                <a class="admin-nav-link" asp-area="Admin" asp-controller="Faqs" asp-action="Index">FAQs</a>
                <a class="admin-nav-link" asp-area="Admin" asp-controller="AppointmentRequests" asp-action="Index">Appointment Requests</a>
                <a class="admin-nav-link" asp-area="Admin" asp-controller="ContactMessages" asp-action="Index">Contact Messages</a>
                <a class="admin-nav-link" asp-area="Admin" asp-controller="SiteSettings" asp-action="Index">Site Settings</a>
                <a class="admin-nav-link" asp-area="Admin" asp-controller="OpeningHours" asp-action="Index">Opening Hours</a>
            </nav>
            <div class="admin-sidebar-footer">
                <span class="card-kicker">Auth Ready</span>
                <p class="mb-0">Add ASP.NET Identity later and protect this area with the future `Admin` role.</p>
            </div>
        </aside>

        <main class="admin-main">
            <header class="admin-topbar">
                <div>
                    <p class="eyebrow mb-1">Content Management</p>
                    <h1 class="admin-page-title">@ViewData["Title"]</h1>
                </div>
                <a class="btn btn-soft" asp-controller="Home" asp-action="Index">View Website</a>
            </header>

            <div class="admin-content">
                <partial name="_AdminStatusMessage" />
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
