@model SiteSettingFormViewModel
@{ ViewData["Title"] = Model.Id.HasValue ? "Edit Site Setting" : "Create Site Setting"; }
<form method="post" class="admin-form-card"><div asp-validation-summary="ModelOnly" class="booking-status booking-status-error" role="alert"></div><div class="row g-4"><div class="col-md-6"><label asp-for="Key" class="form-label"></label><input asp-for="Key" class="form-control booking-input" /></div><div class="col-md-6"><label asp-for="Group" class="form-label"></label><input asp-for="Group" class="form-control booking-input" /></div><div class="col-12"><label asp-for="Value" class="form-label"></label><textarea asp-for="Value" class="form-control booking-input" rows="4"></textarea></div><div class="col-12"><label asp-for="Description" class="form-label"></label><textarea asp-for="Description" class="form-control booking-input" rows="3"></textarea></div></div><div class="admin-form-actions"><button type="submit" class="btn btn-brand">Save Setting</button><a class="btn btn-soft" asp-action="Index">Cancel</a></div></form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
