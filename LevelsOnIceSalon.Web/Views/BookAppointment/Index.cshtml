@model BookAppointmentPageViewModel
@{
    ViewData["Title"] = Model.PageTitle;
}

<section class="page-hero booking-hero">
    <div class="container">
        <div class="services-banner">
            <div class="services-banner-copy">
                <p class="eyebrow">Book Appointment</p>
                <h1 class="display-title page-title">@Model.BannerTitle</h1>
                <p class="hero-copy">@Model.BannerCopy</p>
            </div>
            <aside class="services-banner-aside">
                <p class="eyebrow">Booking Notes</p>
                <p class="u-text-muted mb-0">This is a booking request, not an instant confirmation. We will follow up to confirm availability and the final details.</p>
            </aside>
        </div>
    </div>
</section>

<section class="content-section">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-7">
                <div class="booking-form-shell">
                    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
                    {
                        <div class="booking-status @(Model.IsSuccess ? "booking-status-success" : "booking-status-error")" role="status" aria-live="polite">
                            @Model.StatusMessage
                        </div>
                    }

                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty]?.Errors.Count > 0)
                    {
                        <div class="booking-status booking-status-error" asp-validation-summary="ModelOnly" role="alert"></div>
                    }

                    <form asp-action="Index" asp-controller="BookAppointment" method="post" novalidate class="booking-form">
                        @Html.AntiForgeryToken()
                        <input asp-for="Form.Website" class="booking-honeypot" tabindex="-1" autocomplete="off" aria-hidden="true" />
                        <input asp-for="Form.FormRenderedAtUnix" type="hidden" />
                        <input asp-for="Form.CaptchaToken" type="hidden" />

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label asp-for="Form.FullName" class="form-label"></label>
                                <input asp-for="Form.FullName" class="form-control booking-input" autocomplete="name" />
                                <span asp-validation-for="Form.FullName" class="text-danger field-validation"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Form.PhoneNumber" class="form-label"></label>
                                <input asp-for="Form.PhoneNumber" class="form-control booking-input" autocomplete="tel" />
                                <span asp-validation-for="Form.PhoneNumber" class="text-danger field-validation"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="Form.Email" class="form-label"></label>
                                <input asp-for="Form.Email" class="form-control booking-input" autocomplete="email" />
                                <span asp-validation-for="Form.Email" class="text-danger field-validation"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="Form.PreferredServiceId" class="form-label"></label>
                                <select asp-for="Form.PreferredServiceId" class="form-select booking-input" asp-items="@(new Microsoft.AspNetCore.Mvc.Rendering.SelectList(Model.Services, nameof(ServiceOptionViewModel.Id), nameof(ServiceOptionViewModel.Name)))">
                                    <option value="">Select a service</option>
                                </select>
                                <span asp-validation-for="Form.PreferredServiceId" class="text-danger field-validation"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Form.PreferredDate" class="form-label"></label>
                                <input asp-for="Form.PreferredDate" class="form-control booking-input" type="date" min="@Model.MinimumPreferredDate" />
                                <span asp-validation-for="Form.PreferredDate" class="text-danger field-validation"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Form.PreferredTime" class="form-label"></label>
                                <input asp-for="Form.PreferredTime" class="form-control booking-input" type="time" />
                                <span asp-validation-for="Form.PreferredTime" class="text-danger field-validation"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="Form.Notes" class="form-label"></label>
                                <textarea asp-for="Form.Notes" class="form-control booking-input booking-textarea" rows="5" placeholder="Tell us about the look you want, the occasion, or anything helpful before we confirm your booking."></textarea>
                                <span asp-validation-for="Form.Notes" class="text-danger field-validation"></span>
                            </div>
                            <div class="col-12">
                                @if (Model.Captcha.Enabled)
                                {
                                    <div
                                        class="security-captcha"
                                        data-captcha-provider="@Model.Captcha.Provider"
                                        data-captcha-site-key="@Model.Captcha.SiteKey"
                                        data-captcha-input-id="@Html.IdFor(model => model.Form.CaptchaToken)"></div>
                                    <span asp-validation-for="Form.CaptchaToken" class="text-danger field-validation"></span>
                                }
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-brand btn-lg booking-submit">Send Booking Request</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="section-shell booking-side-panel u-stack-md">
                    <div>
                        <p class="eyebrow">What Happens Next</p>
                        <h2 class="footer-title">Clear, polished, and easy from here.</h2>
                        <p class="u-text-muted">Submit your request, let us review your preferred timing, and expect a follow-up with the details that make your visit feel seamless.</p>
                    </div>
                    <div class="booking-step-card">
                        <strong>1. Tell us what you want</strong>
                        <p>Share the service, timing, and any notes that help us prepare your appointment properly.</p>
                    </div>
                    <div class="booking-step-card">
                        <strong>2. We confirm the details</strong>
                        <p>We will check availability and follow up with everything you need before your visit.</p>
                    </div>
                    <div class="booking-step-card">
                        <strong>3. Arrive ready to be looked after</strong>
                        <p>Walk into a warm, polished salon experience with the details already in place.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    @if (Model.Captcha.Enabled)
    {
        <script src="@Model.Captcha.ScriptSource" async defer></script>
        <script>
            window.levelsOnIceCaptchaRenderers = window.levelsOnIceCaptchaRenderers || [];
            window.levelsOnIceCaptchaRenderers.push(function () {
                document.querySelectorAll(".security-captcha").forEach(function (element) {
                    if (element.dataset.captchaRendered === "true") {
                        return;
                    }

                    var provider = element.dataset.captchaProvider;
                    var siteKey = element.dataset.captchaSiteKey;
                    var input = document.getElementById(element.dataset.captchaInputId);
                    var callback = function (token) {
                        if (input) {
                            input.value = token || "";
                        }
                    };

                    if (provider === "hCaptcha" && window.hcaptcha) {
                        window.hcaptcha.render(element, {
                            sitekey: siteKey,
                            callback: callback,
                            "expired-callback": function () { callback(""); }
                        });
                        element.dataset.captchaRendered = "true";
                        return;
                    }

                    if (window.turnstile) {
                        window.turnstile.render(element, {
                            sitekey: siteKey,
                            callback: callback,
                            "expired-callback": function () { callback(""); }
                        });
                        element.dataset.captchaRendered = "true";
                    }
                });
            });

            window.levelsOnIceCaptchaOnLoad = function () {
                (window.levelsOnIceCaptchaRenderers || []).forEach(function (render) { render(); });
            };
            document.addEventListener("DOMContentLoaded", function () {
                (window.levelsOnIceCaptchaRenderers || []).forEach(function (render) { render(); });
            });
        </script>
    }
}
