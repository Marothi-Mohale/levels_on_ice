@model TestimonialsPageViewModel
@{
    ViewData["Title"] = Model.PageTitle;
}

<section class="page-hero testimonials-hero">
    <div class="container">
        <div class="services-banner">
            <div class="services-banner-copy">
                <p class="eyebrow">Testimonials</p>
                <h1 class="display-title page-title">@Model.BannerTitle</h1>
                <p class="hero-copy">@Model.BannerCopy</p>
                <div class="hero-actions d-flex flex-wrap gap-3 mt-4">
                    <a class="btn btn-brand" href="@Model.PrimaryCta.Url">@Model.PrimaryCta.Label</a>
                    <a class="btn btn-soft" asp-controller="Gallery" asp-action="Index">See The Work</a>
                </div>
            </div>
            <aside class="services-banner-aside">
                <p class="eyebrow">Client Voice</p>
                <p class="u-text-muted mb-0">Real words from women who know exactly how good a beauty appointment should feel.</p>
            </aside>
        </div>
    </div>
</section>

<section class="content-section">
    <div class="container">
        <div class="section-heading">
            <p class="eyebrow">Featured Client Love</p>
            <h2>The finish matters, but so does the feeling clients leave with.</h2>
        </div>
        <partial name="Partials/_TestimonialsCollection" model="Model.FeaturedTestimonials" />
    </div>
</section>

<section class="content-section alt-section">
    <div class="container">
        <div class="section-heading">
            <p class="eyebrow">More Reviews</p>
            <h2>More client notes on the service, the atmosphere, and the standard we keep.</h2>
        </div>
        <partial name="Partials/_TestimonialsCollection" model="Model.Testimonials" />
    </div>
</section>
