@model GalleryPageViewModel
@{
    ViewData["Title"] = Model.PageTitle;
}

<section class="page-hero gallery-hero">
    <div class="container">
        <div class="services-banner">
            <div class="services-banner-copy">
                <p class="eyebrow">Gallery</p>
                <h1 class="display-title page-title">@Model.BannerTitle</h1>
                <p class="hero-copy">@Model.BannerCopy</p>
                <div class="hero-actions d-flex flex-wrap gap-3 mt-4">
                    <a class="btn btn-brand" href="@Model.PrimaryCta.Url">@Model.PrimaryCta.Label</a>
                    <a class="btn btn-soft" href="#gallery-feed">Browse Gallery</a>
                </div>
            </div>
            <aside class="services-banner-aside">
                <p class="eyebrow">Gallery Source</p>
                <p class="u-text-muted mb-3">
                    @(Model.IsUsingDatabaseImages
                        ? "Currently loading from managed gallery records in the database."
                        : "Currently loading from static files in wwwroot/images/salon/.")
                </p>
                <nav class="services-filter-nav gallery-filter-nav" aria-label="Gallery categories">
                    <button type="button" class="services-filter-chip gallery-filter-chip is-active" data-gallery-filter="all" aria-pressed="true">All</button>
                    @foreach (var category in Model.Categories)
                    {
                        <button type="button" class="services-filter-chip gallery-filter-chip" data-gallery-filter="@category" aria-pressed="false">@category</button>
                    }
                </nav>
            </aside>
        </div>
    </div>
</section>

<section id="gallery-feed" class="content-section">
    <div class="container">
        <div class="section-heading">
            <p class="eyebrow">Visual Showcase</p>
            <h2>A premium image layout designed to feel editorial, scroll-friendly, and beautifully easy to explore.</h2>
        </div>
        <div class="gallery-masonry" data-gallery-grid>
            @foreach (var item in Model.Items.OrderByDescending(item => item.IsFeatured).ThenBy(item => item.DisplayOrder))
            {
                <partial name="Partials/_GalleryCard" model="item" />
            }
        </div>
    </div>
</section>

<div class="gallery-lightbox" id="galleryLightbox" hidden aria-hidden="true">
    <div class="gallery-lightbox-dialog" role="dialog" aria-modal="true" aria-labelledby="galleryLightboxTitle">
        <div class="gallery-lightbox-content">
            <button type="button" class="gallery-lightbox-close" data-gallery-close aria-label="Close image viewer"></button>
            <div class="gallery-lightbox-body">
                <img id="galleryLightboxImage" src="" alt="" loading="eager" decoding="async" />
                <div class="gallery-lightbox-copy">
                    <p class="eyebrow" id="galleryLightboxCategory"></p>
                    <h2 id="galleryLightboxTitle"></h2>
                    <p id="galleryLightboxCaption" class="u-text-muted mb-0"></p>
                </div>
            </div>
        </div>
    </div>
</div>
