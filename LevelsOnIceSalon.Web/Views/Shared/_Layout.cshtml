<!DOCTYPE html>
<html lang="en">
<head>
    @using LevelsOnIceSalon.Web.Services
    @using LevelsOnIceSalon.Web.ViewModels
    @{
        var seoMetadata = ViewData.GetSeoMetadata() ?? new SeoMetadataViewModel
        {
            Title = $"{(ViewData["Title"] ?? "Levels On Ice Salon")} | Levels On Ice Salon",
            Description = (ViewData["MetaDescription"] as string) ?? "Modern, classy salon experiences in Mowbray, Cape Town for nails, custom hairstyles, and beauty services."
        };
    }
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#fffaf7" />
    <partial name="Partials/_SeoHead" model="seoMetadata" />
    @await RenderSectionAsync("Head", required: false)
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="site-shell">
    <a class="skip-link" href="#mainContent">Skip to content</a>
    <partial name="Partials/_TopBar" />

    <header class="site-header">
        <nav class="navbar navbar-expand-lg navbar-light site-navbar">
            <div class="container">
                <a class="navbar-brand brand-mark" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark-top">Levels On Ice</span>
                    <span class="brand-mark-bottom">Salon</span>
                </a>
                <button class="navbar-toggler site-toggler" type="button" data-nav-toggle aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="site-toggler-line"></span>
                    <span class="site-toggler-line"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="About" asp-action="Index">About</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Services" asp-action="Index">Services</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Gallery" asp-action="Index">Gallery</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Testimonials" asp-action="Index">Testimonials</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Faqs" asp-action="Index">FAQs</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Contact" asp-action="Index">Contact</a></li>
                        <li class="nav-item"><a class="btn btn-brand btn-brand-nav" asp-controller="BookAppointment" asp-action="Index">Book Now</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main id="mainContent" role="main" tabindex="-1">
        @RenderBody()
    </main>

    <partial name="Partials/_Footer" />
    <partial name="Partials/_MobileBookingCta" />

    <script src="~/js/site.js" asp-append-version="true" defer></script>
    @await Html.PartialAsync("Partials/_ThemeScripts")
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
