@model ContactPageViewModel

<section class="content-section">
    <div class="container">
        <div class="final-cta-banner">
            <div>
                <p class="eyebrow">Ready To Book?</p>
                <h2>If you already know the look, we can help you secure the moment.</h2>
                <p>Skip the back-and-forth and send your booking request directly when you are ready.</p>
            </div>
            <div class="final-cta-actions">
                <a class="btn btn-brand btn-lg" href="@Model.BookingCta.Url">@Model.BookingCta.Label</a>
                <a class="btn btn-soft btn-lg" href="tel:@Model.PhoneNumber.Replace(" ", string.Empty)">Call First</a>
            </div>
        </div>
    </div>
</section>
