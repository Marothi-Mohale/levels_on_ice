@model HomePageViewModel

<section class="homepage-hero">
    <div class="container">
        <div class="row align-items-center g-4 g-lg-5">
            <div class="col-lg-6">
                <div class="hero-content">
                    <p class="eyebrow">Cape Town beauty, polished with intention</p>
                    <h1 class="display-title hero-title">Your next signature look starts at <span class="hero-title-accent">@Model.SalonName</span>.</h1>
                    <p class="hero-copy">Premium nails, soft glam hairstyles, protective styling, and occasion-ready beauty for women who want to feel classy, confident, and camera-ready without the stress.</p>
                    <div class="hero-actions d-flex flex-wrap gap-3">
                        <a class="btn btn-brand btn-lg" asp-controller="BookAppointment" asp-action="Index">Book Your Appointment</a>
                        <a class="btn btn-soft btn-lg" asp-controller="Gallery" asp-action="Index">View The Work</a>
                    </div>
                    <ul class="hero-trust-list" aria-label="Salon trust signals">
                        <li>Trusted by style-conscious clients across Mowbray and Cape Town</li>
                        <li>Walk-ins welcome when space allows</li>
                        <li>Quick booking, premium finish, social-ready results</li>
                    </ul>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="hero-visual-shell">
                    <figure class="hero-visual-main">
                        <img src="~/images/salon/hair-featured-01.jpg" asp-append-version="true" alt="Finished hairstyle showcase from Levels On Ice Salon." loading="eager" />
                    </figure>
                    <figure class="hero-visual-detail">
                        <img src="~/images/salon/nails-featured-01.jpg" asp-append-version="true" alt="Premium nails created at Levels On Ice Salon." loading="lazy" />
                    </figure>
                    <div class="hero-floating-card">
                        <span class="eyebrow">Easy Booking</span>
                        <strong>Appointments made simple</strong>
                        <p>Choose your service, send your request, and let the salon confirm the final details.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
