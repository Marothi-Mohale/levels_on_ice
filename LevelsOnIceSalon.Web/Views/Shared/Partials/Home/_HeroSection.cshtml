@model HomePageViewModel

<section class="homepage-hero">
    <div class="container">
        <div class="row align-items-center g-4 g-lg-5">
            <div class="col-lg-6">
                <div class="hero-content">
                    <p class="eyebrow">Modern beauty, beautifully done</p>
                    <h1 class="display-title hero-title">Polished nails, styled hair, and the kind of finish that makes you feel instantly put together at <span class="hero-title-accent">@Model.SalonName</span>.</h1>
                    <p class="hero-copy">For women who want beauty that feels refined, current, and worth showing up for, from everyday maintenance to your next main-character moment.</p>
                    <div class="hero-actions d-flex flex-wrap gap-3">
                        <a class="btn btn-brand btn-lg" asp-controller="BookAppointment" asp-action="Index">Book Your Visit</a>
                        <a class="btn btn-soft btn-lg" asp-controller="Gallery" asp-action="Index">See The Finish</a>
                    </div>
                    <ul class="hero-trust-list" aria-label="Salon trust signals">
                        <li>Chosen by women across Cape Town who like their beauty polished</li>
                        <li>Warm service, considered detail, and a stylish atmosphere</li>
                        <li>Easy booking for everyday appointments and statement moments</li>
                    </ul>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="hero-visual-shell">
                    <figure class="hero-visual-main">
                        <img src="~/images/salon/hair-featured-01.jpg" asp-append-version="true" alt="Finished hairstyle showcase from Levels On Ice Salon." loading="eager" fetchpriority="high" decoding="async" width="206" height="206" sizes="(min-width: 992px) 30rem, 100vw" />
                    </figure>
                    <figure class="hero-visual-detail">
                        <img src="~/images/salon/nails-featured-01.jpg" asp-append-version="true" alt="Premium nails created at Levels On Ice Salon." loading="lazy" decoding="async" width="206" height="206" sizes="(min-width: 992px) 14rem, 42vw" />
                    </figure>
                    <div class="hero-floating-card">
                        <span class="eyebrow">Book Beautifully</span>
                        <strong>Simple from the first click</strong>
                        <p>Choose your service, send your request, and we will confirm the details with care.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
