@model HomePageViewModel

<section class="content-section">
    <div class="container">
        <div class="social-proof-shell">
            <div class="section-heading">
                <p class="eyebrow">Beauty Mood</p>
                <h2>The brand lives in the details: polished finishes, feminine styling, and looks worth saving.</h2>
            </div>
            <div class="social-proof-grid">
                <article class="social-proof-card">
                    <span class="social-proof-tag">After look</span>
                    <h3>Nail sets with presence</h3>
                    <p>Clean detail, glossy finish, and the kind of hands you keep looking at all day.</p>
                </article>
                <article class="social-proof-card">
                    <span class="social-proof-tag">Styled now</span>
                    <h3>Protective styles with softness</h3>
                    <p>Neat, feminine, and beautifully shaped without losing personality.</p>
                </article>
                <article class="social-proof-card">
                    <span class="social-proof-tag">Occasion ready</span>
                    <h3>Looks for moments that matter</h3>
                    <p>For birthdays, matric, bridal events, and any day you want to arrive looking fully finished.</p>
                </article>
            </div>
        </div>
    </div>
</section>
