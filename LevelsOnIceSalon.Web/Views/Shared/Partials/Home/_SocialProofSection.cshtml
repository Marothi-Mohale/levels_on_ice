@model HomePageViewModel

<section class="content-section">
    <div class="container">
        <div class="social-proof-shell">
            <div class="section-heading">
                <p class="eyebrow">Social Proof Energy</p>
                <h2>A homepage that feels inspired by the confidence of beauty content, not cluttered by it.</h2>
            </div>
            <div class="social-proof-grid">
                <article class="social-proof-card">
                    <span class="social-proof-tag">After look</span>
                    <h3>Soft luxury nail sets</h3>
                    <p>Built for close-up content, everyday confidence, and polished hand-detail moments.</p>
                </article>
                <article class="social-proof-card">
                    <span class="social-proof-tag">Trending now</span>
                    <h3>Protective styles with personality</h3>
                    <p>Neat, feminine, and current looks that still feel elevated enough for premium clients.</p>
                </article>
                <article class="social-proof-card">
                    <span class="social-proof-tag">Special occasion</span>
                    <h3>Ready for matric, bridal, birthdays</h3>
                    <p>Beauty styling that helps clients feel fully put together for milestone moments and camera time.</p>
                </article>
            </div>
        </div>
    </div>
</section>
