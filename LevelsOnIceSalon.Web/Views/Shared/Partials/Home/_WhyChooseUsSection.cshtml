@model HomePageViewModel

<section class="content-section">
    <div class="container">
        <div class="section-heading">
            <p class="eyebrow">Why Choose Us</p>
            <h2>Luxury energy, youthful style, and a salon experience that feels worth dressing up for.</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <article class="feature-card feature-card-accent">
                    <span class="card-kicker">01</span>
                    <h3>Looks that feel expensive</h3>
                    <p>Every set, style, and finishing touch is designed to look polished in real life and even better in photos.</p>
                </article>
            </div>
            <div class="col-md-4">
                <article class="feature-card">
                    <span class="card-kicker">02</span>
                    <h3>Trend-aware, never overdone</h3>
                    <p>Perfect for women who want soft luxury, event-ready glam, or statement beauty without losing elegance.</p>
                </article>
            </div>
            <div class="col-md-4">
                <article class="feature-card">
                    <span class="card-kicker">03</span>
                    <h3>Comfort meets confidence</h3>
                    <p>From refreshments and WiFi to a warm, stylish atmosphere, the whole experience is designed to feel easy.</p>
                </article>
            </div>
        </div>
    </div>
</section>
