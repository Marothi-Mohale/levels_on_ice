@model HomePageViewModel

<section class="content-section">
    <div class="container">
        <div class="section-heading">
            <p class="eyebrow">Why Choose Us</p>
            <h2>Everything is designed to feel polished, current, and quietly special from the moment you walk in.</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <article class="feature-card feature-card-accent">
                    <span class="card-kicker">01</span>
                    <h3>Beauty that looks considered</h3>
                    <p>Every set, style, and finishing detail is shaped to feel refined in person and beautiful on camera.</p>
                </article>
            </div>
            <div class="col-md-4">
                <article class="feature-card">
                    <span class="card-kicker">02</span>
                    <h3>Modern, not try-hard</h3>
                    <p>Current enough to feel fresh, polished enough to stay elegant, and styled with real women in mind.</p>
                </article>
            </div>
            <div class="col-md-4">
                <article class="feature-card">
                    <span class="card-kicker">03</span>
                    <h3>Warm service, real attention</h3>
                    <p>From the atmosphere to the after-look, the experience feels calm, welcoming, and beautifully cared for.</p>
                </article>
            </div>
        </div>
    </div>
</section>
