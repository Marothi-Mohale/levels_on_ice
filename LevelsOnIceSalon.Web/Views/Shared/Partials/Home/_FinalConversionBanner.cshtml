@model HomePageViewModel

<section class="content-section">
    <div class="container">
        <div class="final-cta-banner">
            <div>
                <p class="eyebrow">Ready When You Are</p>
                <h2>Book the look, secure the slot, and let the salon handle the rest.</h2>
                <p>Whether it’s everyday polish or a big-event moment, the next appointment should feel easy to say yes to.</p>
            </div>
            <div class="final-cta-actions">
                <a class="btn btn-brand btn-lg" asp-controller="BookAppointment" asp-action="Index">Request Appointment</a>
                <a class="btn btn-soft btn-lg" asp-controller="Services" asp-action="Index">Browse Services</a>
            </div>
        </div>
    </div>
</section>
