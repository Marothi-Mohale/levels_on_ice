@model HomePageViewModel

<section class="content-section">
    <div class="container">
        <div class="final-cta-banner">
            <div>
                <p class="eyebrow">Ready When You Are</p>
                <h2>Your next appointment should feel easy to choose and even better to arrive for.</h2>
                <p>Whether you want fresh maintenance or a full occasion look, we make the next step feel beautifully simple.</p>
            </div>
            <div class="final-cta-actions">
                <a class="btn btn-brand btn-lg" asp-controller="BookAppointment" asp-action="Index">Book Your Visit</a>
                <a class="btn btn-soft btn-lg" asp-controller="Services" asp-action="Index">Explore Services</a>
            </div>
        </div>
    </div>
</section>
