@model HomePageViewModel

<section class="content-section alt-section">
    <div class="container">
        <div class="location-cta-grid">
            <div class="section-shell">
                <p class="eyebrow">Visit Us</p>
                <h2 class="footer-title">Your next polished moment starts in Mowbray.</h2>
                <p class="u-text-muted">Stop in for a walk-in when space allows, or send a booking request for the look you already know you want.</p>
            </div>
            <aside class="section-shell location-card">
                <div class="u-stack-sm">
                    <p class="eyebrow">Contact Snapshot</p>
                    <p><strong>Address:</strong> @Model.Address</p>
                    <p><strong>Phone:</strong> <a href="tel:0813906634">@Model.PhoneNumber</a></p>
                    <p><strong>Email:</strong> <a href="mailto:@Model.Email">@Model.Email</a></p>
                </div>
                <div class="hero-actions d-flex flex-wrap gap-3">
                    <a class="btn btn-brand" asp-controller="BookAppointment" asp-action="Index">Book Your Visit</a>
                    <a class="btn btn-soft" asp-controller="Contact" asp-action="Index">Get In Touch</a>
                </div>
            </aside>
        </div>
    </div>
</section>
