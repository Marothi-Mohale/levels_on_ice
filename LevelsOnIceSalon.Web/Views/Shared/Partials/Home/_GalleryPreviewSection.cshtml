@model HomePageViewModel

<section class="content-section">
    <div class="container">
        <div class="section-heading">
            <p class="eyebrow">Gallery Preview</p>
            <h2>Finished looks that make booking feel exciting before you even step through the door.</h2>
        </div>
        <div class="homepage-gallery-grid">
            <figure class="homepage-gallery-card gallery-card-large">
                <img src="~/images/salon/nails-featured-02.jpg" asp-append-version="true" alt="Polished nail artistry from Levels On Ice Salon." loading="lazy" />
                <figcaption>Polished nail artistry</figcaption>
            </figure>
            <figure class="homepage-gallery-card gallery-card-tall">
                <img src="~/images/salon/hair-braids-boho-01.jpg" asp-append-version="true" alt="Boho braid styling from Levels On Ice Salon." loading="lazy" />
                <figcaption>Boho braid energy</figcaption>
            </figure>
            <figure class="homepage-gallery-card">
                <img src="~/images/salon/nails-detail-02.jpg" asp-append-version="true" alt="Close-up nail detail from Levels On Ice Salon." loading="lazy" />
                <figcaption>Soft luxury finishes</figcaption>
            </figure>
            <figure class="homepage-gallery-card gallery-card-wide">
                <img src="~/images/salon/salon-interior-02.jpg" asp-append-version="true" alt="Interior view of Levels On Ice Salon in Mowbray." loading="lazy" />
                <figcaption>Editorial beauty atmosphere</figcaption>
            </figure>
        </div>
        <div class="section-actions">
            <a class="btn btn-soft" asp-controller="Gallery" asp-action="Index">See Full Gallery</a>
        </div>
    </div>
</section>
