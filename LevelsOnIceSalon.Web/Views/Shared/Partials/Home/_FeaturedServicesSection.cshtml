@model HomePageViewModel

<section class="content-section alt-section">
    <div class="container">
        <div class="section-heading">
            <p class="eyebrow">Featured Services</p>
            <h2>The salon menu is built for girls who want polished beauty with personality.</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-xl-3">
                <article class="feature-card service-spotlight-card">
                    <p class="service-spotlight-type">Nails</p>
                    <h3>Gloss Theory Gel Set</h3>
                    <p>A sleek, expensive-looking gel finish for everyday confidence, birthdays, and soft luxury moments.</p>
                    <div class="service-spotlight-meta">
                        <span>From R320</span>
                        <span>80 mins</span>
                    </div>
                </article>
            </div>
            <div class="col-md-6 col-xl-3">
                <article class="feature-card service-spotlight-card">
                    <p class="service-spotlight-type">Hair</p>
                    <h3>Silk Press & Sway Finish</h3>
                    <p>For smooth movement, healthy shine, and a soft glam result that still feels modern and youthful.</p>
                    <div class="service-spotlight-meta">
                        <span>From R650</span>
                        <span>120 mins</span>
                    </div>
                </article>
            </div>
            <div class="col-md-6 col-xl-3">
                <article class="feature-card service-spotlight-card">
                    <p class="service-spotlight-type">Protective</p>
                    <h3>Boho Knotless Luxe</h3>
                    <p>Romantic protective styling with soft detail, movement, and a finish that turns into content on its own.</p>
                    <div class="service-spotlight-meta">
                        <span>From R1350</span>
                        <span>360 mins</span>
                    </div>
                </article>
            </div>
            <div class="col-md-6 col-xl-3">
                <article class="feature-card service-spotlight-card">
                    <p class="service-spotlight-type">Occasion</p>
                    <h3>Matric Dance Signature Glam</h3>
                    <p>A polished celebration look for entrance moments, photos, and unforgettable confidence all night long.</p>
                    <div class="service-spotlight-meta">
                        <span>From R1200</span>
                        <span>180 mins</span>
                    </div>
                </article>
            </div>
        </div>
        <div class="section-actions">
            <a class="btn btn-brand" asp-controller="Services" asp-action="Index">Explore All Services</a>
        </div>
    </div>
</section>
