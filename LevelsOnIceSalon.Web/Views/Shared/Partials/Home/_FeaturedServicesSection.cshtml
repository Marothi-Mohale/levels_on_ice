@model HomePageViewModel

<section class="content-section alt-section">
    <div class="container">
        <div class="section-heading">
            <p class="eyebrow">Featured Services</p>
            <h2>A curated menu for women who like their beauty refined, feminine, and unmistakably well done.</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-xl-3">
                <article class="feature-card service-spotlight-card">
                    <p class="service-spotlight-type">Nails</p>
                    <h3>Gloss Theory Gel Set</h3>
                    <p>Clean, glossy, and quietly striking for everyday polish, birthdays, and everything in between.</p>
                    <div class="service-spotlight-meta">
                        <span>From R320</span>
                        <span>80 mins</span>
                    </div>
                </article>
            </div>
            <div class="col-md-6 col-xl-3">
                <article class="feature-card service-spotlight-card">
                    <p class="service-spotlight-type">Hair</p>
                    <h3>Silk Press & Sway Finish</h3>
                    <p>Silk, movement, and shine with a finish that feels effortlessly elevated.</p>
                    <div class="service-spotlight-meta">
                        <span>From R650</span>
                        <span>120 mins</span>
                    </div>
                </article>
            </div>
            <div class="col-md-6 col-xl-3">
                <article class="feature-card service-spotlight-card">
                    <p class="service-spotlight-type">Protective</p>
                    <h3>Boho Knotless Luxe</h3>
                    <p>Protective styling with softness, shape, and a beautifully styled finish.</p>
                    <div class="service-spotlight-meta">
                        <span>From R1350</span>
                        <span>360 mins</span>
                    </div>
                </article>
            </div>
            <div class="col-md-6 col-xl-3">
                <article class="feature-card service-spotlight-card">
                    <p class="service-spotlight-type">Occasion</p>
                    <h3>Matric Dance Signature Glam</h3>
                    <p>Styled for entrance moments, camera flashes, and feeling unforgettable all evening.</p>
                    <div class="service-spotlight-meta">
                        <span>From R1200</span>
                        <span>180 mins</span>
                    </div>
                </article>
            </div>
        </div>
        <div class="section-actions">
            <a class="btn btn-brand" asp-controller="Services" asp-action="Index">Explore The Menu</a>
        </div>
    </div>
</section>
