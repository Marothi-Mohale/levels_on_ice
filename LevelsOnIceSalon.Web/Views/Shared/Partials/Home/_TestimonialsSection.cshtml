@model HomePageViewModel

<section class="content-section alt-section">
    <div class="container">
        <div class="section-heading">
            <p class="eyebrow">Client Love</p>
            <h2>Beauty clients return for the finish, the feeling, and how effortless the whole experience is.</h2>
        </div>
        <div class="testimonials-strip" aria-label="Client testimonials">
            <article class="testimonial-card">
                <div class="testimonial-stars" aria-hidden="true">★★★★★</div>
                <p>“My nails looked expensive, clean, and feminine. I left feeling like the best version of myself.”</p>
                <strong>Zinhle, Cape Town</strong>
            </article>
            <article class="testimonial-card">
                <div class="testimonial-stars" aria-hidden="true">★★★★★</div>
                <p>“The hairstyle was soft glam perfection. It held beautifully and looked incredible in every photo.”</p>
                <strong>Anele, Mowbray</strong>
            </article>
            <article class="testimonial-card">
                <div class="testimonial-stars" aria-hidden="true">★★★★★</div>
                <p>“You can feel the quality in the details. The salon is stylish, welcoming, and the results speak for themselves.”</p>
                <strong>Kayla, Observatory</strong>
            </article>
        </div>
    </div>
</section>
