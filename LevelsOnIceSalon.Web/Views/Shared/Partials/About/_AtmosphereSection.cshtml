@model AboutPageViewModel

<section class="content-section alt-section">
    <div class="container">
        <div class="section-shell">
            <div class="section-heading">
                <p class="eyebrow">Atmosphere & Experience</p>
                <h2>The feeling is calm, polished, and welcoming from the first hello.</h2>
            </div>
            <div class="row g-4 align-items-start">
                <div class="col-lg-7">
                    <p class="about-story-copy">@Model.Atmosphere</p>
                </div>
                <div class="col-lg-5">
                    <div class="perks-panel u-stack-sm">
                        <div class="perk-chip">Free WiFi while you relax</div>
                        <div class="perk-chip">Complimentary refreshments</div>
                        <div class="perk-chip">Walk-ins welcome when available</div>
                        <div class="perk-chip">A stylish, client-first environment</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
