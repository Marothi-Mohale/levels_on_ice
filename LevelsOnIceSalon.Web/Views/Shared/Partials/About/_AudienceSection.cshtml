@model AboutPageViewModel

<section class="content-section">
    <div class="container">
        <div class="location-cta-grid">
            <div class="section-shell">
                <p class="eyebrow">Audience Fit</p>
                <h2 class="footer-title">Made for women who want their beauty to feel elevated without feeling overdone.</h2>
                <p class="u-text-muted">@Model.AudienceFit</p>
            </div>
            <aside class="section-shell about-side-card">
                <p class="eyebrow">Who It’s For</p>
                <ul class="about-fit-list">
                    <li>Women who love polished beauty with personality</li>
                    <li>Clients booking for birthdays, matric, weddings, or styled weekends</li>
                    <li>Anyone who wants a chic salon that still feels welcoming</li>
                </ul>
            </aside>
        </div>
    </div>
</section>
