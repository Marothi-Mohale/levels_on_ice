@model AboutPageViewModel

<section class="content-section">
    <div class="container">
        <div class="location-cta-grid">
            <div class="section-shell">
                <p class="eyebrow">Audience Fit</p>
                <h2 class="footer-title">Premium enough for bridal and events, easy enough for everyday beauty maintenance.</h2>
                <p class="u-text-muted">@Model.AudienceFit</p>
            </div>
            <aside class="section-shell about-side-card">
                <p class="eyebrow">Who It’s For</p>
                <ul class="about-fit-list">
                    <li>Young women who love polished beauty with personality</li>
                    <li>Clients booking for birthdays, matric, weddings, or content days</li>
                    <li>Women who want a stylish salon that still feels approachable</li>
                </ul>
            </aside>
        </div>
    </div>
</section>
