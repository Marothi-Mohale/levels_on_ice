@model AboutPageViewModel

<section class="content-section alt-section">
    <div class="container">
        <div class="section-heading">
            <p class="eyebrow">What Makes Us Different</p>
            <h2>Clients choose Levels On Ice because the standard shows in both the styling and the service.</h2>
        </div>
        <div class="row g-4">
            @foreach (var point in Model.DifferencePoints)
            {
                <div class="col-md-4">
                    <article class="feature-card feature-card-accent">
                        <h3>@point.Title</h3>
                        <p>@point.Description</p>
                    </article>
                </div>
            }
        </div>
    </div>
</section>
