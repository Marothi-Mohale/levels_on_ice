@model AboutPageViewModel

<section class="page-hero about-hero">
    <div class="container">
        <div class="row align-items-center g-4 g-lg-5">
            <div class="col-lg-6">
                <p class="eyebrow">@Model.NavigationTitle</p>
                <h1 class="display-title page-title">A salon brand created for women who love beauty with polish, confidence, and presence.</h1>
                <p class="hero-copy">@Model.Intro</p>
                <div class="hero-actions d-flex flex-wrap gap-3 mt-4">
                    <a class="btn btn-brand" asp-controller="BookAppointment" asp-action="Index">@Model.PrimaryCta.Label</a>
                    <a class="btn btn-soft" asp-controller="Gallery" asp-action="Index">View Gallery</a>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="hero-visual-shell">
                    <figure class="hero-visual-main">
                        <img src="~/images/salon/salon-interior-01.jpg" asp-append-version="true" alt="Interior atmosphere at Levels On Ice Salon." loading="eager" fetchpriority="high" decoding="async" width="768" height="768" sizes="(min-width: 992px) 30rem, 100vw" />
                    </figure>
                    <div class="hero-floating-card">
                        <span class="eyebrow">Brand Mood</span>
                        <strong>Fashion-forward. Warm. Beautifully considered.</strong>
                        <p>Everything from the atmosphere to the final finish is designed to feel elevated without ever feeling cold.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
