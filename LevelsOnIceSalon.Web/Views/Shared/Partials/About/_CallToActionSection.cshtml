@model AboutPageViewModel

<section class="content-section">
    <div class="container">
        <div class="final-cta-banner">
            <div>
                <p class="eyebrow">Book The Experience</p>
                <h2>If the brand feels like you, the next step should be simple.</h2>
                <p>Send your appointment request and let us help you plan a look that feels polished, current, and completely yours.</p>
            </div>
            <div class="final-cta-actions">
                <a class="btn btn-brand btn-lg" asp-controller="BookAppointment" asp-action="Index">@Model.PrimaryCta.Label</a>
                <a class="btn btn-soft btn-lg" asp-controller="Contact" asp-action="Index">Get In Touch</a>
            </div>
        </div>
    </div>
</section>
