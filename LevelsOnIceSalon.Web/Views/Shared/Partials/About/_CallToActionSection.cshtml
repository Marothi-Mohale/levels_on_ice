@model AboutPageViewModel

<section class="content-section">
    <div class="container">
        <div class="final-cta-banner">
            <div>
                <p class="eyebrow">Book The Experience</p>
                <h2>When the brand feels right, the next step should be easy.</h2>
                <p>Send your appointment request and let Levels On Ice Salon help you plan the next look you’ll feel amazing in.</p>
            </div>
            <div class="final-cta-actions">
                <a class="btn btn-brand btn-lg" asp-controller="BookAppointment" asp-action="Index">@Model.PrimaryCta.Label</a>
                <a class="btn btn-soft btn-lg" asp-controller="Contact" asp-action="Index">Contact The Salon</a>
            </div>
        </div>
    </div>
</section>
