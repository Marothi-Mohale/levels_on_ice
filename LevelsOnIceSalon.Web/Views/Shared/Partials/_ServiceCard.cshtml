@model ServiceCardViewModel

<article class="feature-card service-catalog-card @(Model.IsFeatured ? "service-catalog-card-featured" : string.Empty)">
    @if (Model.IsFeatured)
    {
        <span class="service-feature-badge">Featured</span>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
    {
        <figure class="service-card-media">
            <img src="@Model.ImageUrl" alt="@Model.ImageAltText" loading="lazy" decoding="async" width="@Model.ImageWidth" height="@Model.ImageHeight" sizes="(min-width: 1200px) 22rem, (min-width: 768px) 45vw, 100vw" />
        </figure>
    }
    <div class="u-stack-sm">
        <h3>@Model.Name</h3>
        <p class="service-summary">@Model.Summary</p>
        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <p class="service-description">@Model.Description</p>
        }
    </div>
    <div class="service-catalog-meta">
        <span>@Model.DurationText</span>
        <span>@Model.PriceText</span>
    </div>
    <a class="btn btn-brand service-card-cta" href="@Model.BookingUrl">Book This Look</a>
</article>
