@model HomePageViewModel
@{
    ViewData["Title"] = "Home";
}

<section class="hero-section">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <p class="eyebrow">Premium beauty for everyday glow and standout occasions</p>
                <h1 class="display-title">@Model.SalonName</h1>
                <p class="hero-copy">@Model.Tagline From soft glam polish to statement sets and custom hairstyles, the brand experience should feel chic, youthful, and beautifully considered from the first scroll.</p>
                <div class="hero-actions d-flex flex-wrap gap-3 mt-4">
                    <a class="btn btn-brand btn-lg" href="#booking">Request Appointment</a>
                    <a class="btn btn-soft btn-lg" href="#gallery">View Gallery</a>
                </div>
                <div class="hero-badges mt-4">
                    <span>Free WiFi</span>
                    <span>Refreshments</span>
                    <span>Walk-ins Welcome</span>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="hero-card">
                    <div class="hero-card-media">
                        <div class="hero-orb hero-orb-one"></div>
                        <div class="hero-orb hero-orb-two"></div>
                        <div class="hero-photo-stack">
                            <div class="hero-photo-tile hero-photo-large">Bridal-ready style</div>
                            <div class="hero-photo-tile hero-photo-small">Nail artistry</div>
                        </div>
                    </div>
                    <div class="hero-card-copy">
                        <p class="eyebrow mb-2">Signature Beauty Destination</p>
                        <h2>Premium nails, custom hairstyles, and polished beauty services for every occasion.</h2>
                        <p class="mb-0">Use your salon images in <strong>wwwroot/images/salon</strong> for elegant portraits, polished close-ups, and high-quality final looks that feel editorial rather than generic.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="experience" class="content-section section-experience">
    <div class="container">
        <div class="section-shell">
            <div class="section-heading">
                <p class="eyebrow">Brand Mood</p>
                <h2>Young, polished, feminine, and premium without feeling overdone.</h2>
            </div>
            <div class="row g-4">
                <div class="col-md-4">
                    <article class="feature-card feature-card-accent">
                        <span class="card-kicker">01</span>
                        <h3>Bridal-worthy elegance</h3>
                        <p>Soft luxury styling, graceful typography, and elevated image framing for higher-end clients and special occasions.</p>
                    </article>
                </div>
                <div class="col-md-4">
                    <article class="feature-card">
                        <span class="card-kicker">02</span>
                        <h3>Social-first polish</h3>
                        <p>Layouts that make finished looks feel shareable, modern, and aspirational for the 15 to 35 audience.</p>
                    </article>
                </div>
                <div class="col-md-4">
                    <article class="feature-card">
                        <span class="card-kicker">03</span>
                        <h3>Clear luxury cues</h3>
                        <p>Refined spacing, strong calls to action, and subtle depth instead of flashy clutter or overused template patterns.</p>
                    </article>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="services" class="content-section">
    <div class="container">
        <div class="section-heading">
            <p class="eyebrow">What We Do</p>
            <h2>Beauty services tailored for confidence and style.</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <article class="feature-card service-card">
                    <h3>Nails</h3>
                    <p>Statement sets, elegant finishes, and premium nail care designed to photograph beautifully.</p>
                    <a class="text-link" href="#booking">Book this service</a>
                </article>
            </div>
            <div class="col-md-4">
                <article class="feature-card service-card">
                    <h3>Custom Hairstyles</h3>
                    <p>Looks created with personality, trend-awareness, and occasion-ready styling in mind.</p>
                    <a class="text-link" href="#booking">Book this service</a>
                </article>
            </div>
            <div class="col-md-4">
                <article class="feature-card service-card">
                    <h3>Beauty Services</h3>
                    <p>Refined touch-ups and finishing services that complete the full salon experience.</p>
                    <a class="text-link" href="#booking">Book this service</a>
                </article>
            </div>
        </div>
    </div>
</section>

<section id="gallery" class="content-section alt-section">
    <div class="container">
        <div class="section-heading">
            <p class="eyebrow">Visual Storytelling</p>
            <h2>Your finished looks deserve a premium gallery.</h2>
        </div>
        <div class="gallery-grid">
            <div class="gallery-tile"><span>Clean nail artistry</span></div>
            <div class="gallery-tile tall"><span>Occasion hair styling</span></div>
            <div class="gallery-tile"><span>Soft glam finish</span></div>
            <div class="gallery-tile wide"><span>Editorial after-look photography</span></div>
        </div>
    </div>
</section>

<section id="booking" class="content-section">
    <div class="container">
        <div class="booking-panel">
            <div>
                <p class="eyebrow">Bookings</p>
                <h2>Ready for your next appointment?</h2>
                <p class="mb-0">The final booking form will live here with service selection, preferred date and time, and contact details stored in PostgreSQL for admin follow-up.</p>
            </div>
            <div class="booking-contact">
                <p class="mb-2"><strong>Call:</strong> @Model.PhoneNumber</p>
                <p class="mb-2"><strong>Email:</strong> @Model.Email</p>
                <p class="mb-0"><strong>Visit:</strong> @Model.Address</p>
            </div>
        </div>
    </div>
</section>
